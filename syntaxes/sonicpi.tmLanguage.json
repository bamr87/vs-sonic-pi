{
  "name": "Sonic Pi",
  "scopeName": "source.sonicpi",
  "fileTypes": ["spi", "sonicpi"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#symbols" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#sonicpi-control" },
    { "include": "#sonicpi-sound" },
    { "include": "#sonicpi-core" },
    { "include": "#sonicpi-theory" },
    { "include": "#sonicpi-data" },
    { "include": "#sonicpi-random" },
    { "include": "#sonicpi-io" },
    { "include": "#sonicpi-opts" },
    { "include": "#constants" },
    { "include": "#variables" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.sonicpi",
          "match": "#.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.sonicpi",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.sonicpi",
              "match": "\\\\."
            },
            {
              "name": "meta.embedded.expression.sonicpi",
              "begin": "#\\{",
              "end": "\\}",
              "patterns": [{ "include": "$self" }]
            }
          ]
        },
        {
          "name": "string.quoted.single.sonicpi",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.sonicpi",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "symbols": {
      "patterns": [
        {
          "name": "constant.language.symbol.sonicpi",
          "match": ":[a-zA-Z_][a-zA-Z0-9_]*"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.sonicpi",
          "match": "\\b\\d+\\.\\d+\\b"
        },
        {
          "name": "constant.numeric.integer.sonicpi",
          "match": "\\b\\d+\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.ruby.sonicpi",
          "match": "\\b(do|end|if|else|elsif|unless|while|until|for|begin|rescue|ensure|raise|return|yield|then|case|when|and|or|not|in)\\b"
        },
        {
          "name": "constant.language.boolean.sonicpi",
          "match": "\\b(true|false|nil)\\b"
        },
        {
          "name": "keyword.other.def.sonicpi",
          "match": "\\b(def|class|module|require|include|extend|attr_accessor|attr_reader|attr_writer|lambda|proc)\\b"
        }
      ]
    },
    "sonicpi-control": {
      "patterns": [
        {
          "name": "keyword.control.sonicpi",
          "match": "\\b(live_loop|in_thread|with_fx|with_synth|with_bpm|with_bpm_mul|with_sample_bpm|with_random_seed|with_random_source|with_synth_defaults|with_merged_synth_defaults|with_sample_defaults|with_merged_sample_defaults|with_arg_bpm_scaling|with_timing_guarantees|with_timing_warnings|with_debug|with_arg_checks|with_osc|with_osc_logging|with_cue_logging|with_cent_tuning|with_octave|with_swing|define|defonce|comment|uncomment|density|at|time_warp|on)\\b"
        }
      ]
    },
    "sonicpi-sound": {
      "patterns": [
        {
          "name": "support.function.sound.sonicpi",
          "match": "\\b(play|play_pattern|play_pattern_timed|play_chord|sample|synth|control|kill|stop|use_synth|use_bpm|use_bpm_mul|use_sample_bpm|use_synth_defaults|use_merged_synth_defaults|use_sample_defaults|use_merged_sample_defaults|use_arg_bpm_scaling|use_timing_guarantees|use_timing_warnings|use_debug|use_arg_checks|use_external_synths|use_osc|use_osc_logging|use_random_seed|use_random_source|use_cue_logging|use_cent_tuning|use_octave|set_volume!|set_mixer_control!|reset_mixer!|set_control_delta!|set_audio_latency!|set_recording_bit_depth!|recording_start|recording_stop|recording_save|recording_delete|load_sample|load_samples|load_sample_at_path|load_synthdef|load_synthdefs|sample_free|sample_free_all|sample_loaded\\?|sample_info|sample_buffer|sample_duration|sample_paths|sample_names|sample_groups|all_sample_names|synth_names|fx_names|buffer|buffer_save|live_audio|reboot|status|start_amp_monitor|current_amp|current_synth|current_synth_defaults|current_sample_defaults|current_volume|current_debug|current_arg_checks)\\b"
        }
      ]
    },
    "sonicpi-core": {
      "patterns": [
        {
          "name": "support.function.core.sonicpi",
          "match": "\\b(sleep|wait|cue|sync|sync_bpm|set|get|tick|tick_set|tick_reset|tick_reset_all|look|puts|print|run_file|run_code|eval_file|load_buffer|reset|clear|vt|beat|rt|current_bpm|current_bpm_mode|block_duration|block_slept\\?|osc|osc_send|spark|assert|assert_equal|assert_similar|assert_error|assert_not|assert_not_equal|live_state)\\b"
        }
      ]
    },
    "sonicpi-theory": {
      "patterns": [
        {
          "name": "support.function.theory.sonicpi",
          "match": "\\b(note|note_info|note_range|scale|chord|chord_degree|chord_invert|chord_names|scale_names|degree|midi_notes|hz_to_midi|midi_to_hz|pitch_to_ratio|ratio_to_pitch)\\b"
        }
      ]
    },
    "sonicpi-data": {
      "patterns": [
        {
          "name": "support.function.data.sonicpi",
          "match": "\\b(ring|vector|map|ramp|bools|stretch|knit|spread|range|line|halves|doubles|choose|pick|redistribute|tuplets|factor\\?|quantise)\\b"
        }
      ]
    },
    "sonicpi-random": {
      "patterns": [
        {
          "name": "support.function.random.sonicpi",
          "match": "\\b(rand|rand_i|rrand|rrand_i|rdist|dice|one_in|rand_look|rand_i_look|rand_back|rand_skip|rand_reset)\\b"
        }
      ]
    },
    "sonicpi-io": {
      "patterns": [
        {
          "name": "support.function.io.sonicpi",
          "match": "\\b(midi|midi_cc|midi_note_on|midi_note_off|midi_pitch_bend|midi_channel_pressure|midi_poly_pressure|midi_raw|midi_clock_tick|midi_start|midi_stop|midi_continue|midi_local_control_off|midi_local_control_on|midi_mode|midi_reset|midi_sound_off|use_midi_defaults|with_midi_defaults|use_merged_midi_defaults|with_merged_midi_defaults|current_midi_defaults|midi_all_notes_off|midi_pc|midi_sysex)\\b"
        }
      ]
    },
    "sonicpi-opts": {
      "patterns": [
        {
          "name": "variable.parameter.option.sonicpi",
          "match": "\\b(amp|pan|attack|decay|sustain|release|attack_level|decay_level|sustain_level|env_curve|note|cutoff|cutoff_min|cutoff_max|cutoff_attack|cutoff_decay|cutoff_sustain|cutoff_release|cutoff_attack_level|cutoff_decay_level|cutoff_sustain_level|cutoff_env_curve|res|rate|start|finish|pitch|window_size|pitch_dis|time_dis|compress|threshold|slope_above|slope_below|clamp_time|relax_time|pre_amp|mix|phase|pulse_width|range|detune|divisor|depth|delay|max_delay|decay_time|damping|room|damp|spread|num_chans|seed|probability|prob_pos|rpitch|onset|slice|num_slices|beat_stretch|pitch_stretch):"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.other.ruby.sonicpi",
          "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
        }
      ]
    },
    "variables": {
      "patterns": [
        {
          "name": "variable.other.global.sonicpi",
          "match": "\\$[a-zA-Z_][a-zA-Z0-9_]*"
        },
        {
          "name": "variable.other.instance.sonicpi",
          "match": "@[a-zA-Z_][a-zA-Z0-9_]*"
        },
        {
          "name": "variable.parameter.block.sonicpi",
          "match": "\\|[^|]*\\|"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.sonicpi",
          "match": "(\\+|\\-|\\*|\\/|%|==|!=|<|>|<=|>=|&&|\\|\\||!|=|\\+=|\\-=|\\*=|\\.\\.|\\.\\.\\.|<=>|=>)"
        }
      ]
    }
  }
}
