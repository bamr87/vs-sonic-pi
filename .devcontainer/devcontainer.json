{
  "name": "Sonic Pi for VS Code",
  "build": {
    "dockerfile": "Dockerfile",
    "args": {
      "SONIC_PI_BRANCH": "stable"
    }
  },
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "20"
    }
  },
  "forwardPorts": [8080],
  "portsAttributes": {
    "8080": {
      "label": "Sonic Pi Audio Stream",
      "onAutoForward": "notify",
      "protocol": "http"
    }
  },
  "postCreateCommand": "npm install",
  "postStartCommand": "/usr/local/bin/start-audio.sh",
  "runArgs": ["--cap-add=SYS_NICE", "--shm-size=256m"],
  "customizations": {
    "vscode": {
      "extensions": [
        "bamr87.vs-sonic-pi"
      ],
      "settings": {
        "sonicpi.sonicPiPath": "/opt/sonic-pi",
        "sonicpi.autoConnect": true
      }
    }
  },
  "remoteEnv": {
    "PULSE_SERVER": "unix:/tmp/pulse-socket",
    "SONIC_PI_HOME": "/opt/sonic-pi"
  }
}
